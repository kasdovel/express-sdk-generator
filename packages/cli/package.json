{
  "name": "@sdkgen/cli",
  "version": "0.0.0",
  "description": "CLI that generates OpenAPI spec, docs, and a typed TS SDK from a @sdkgen/core registry",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sdkgen": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@sdkgen/core": "workspace:*",
    "commander": "^12.1.0",
    "jiti": "^2.4.2",
    "redoc": "^2.2.0",
    "swagger-ui-dist": "^5.18.2",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "zod": "^3.24.1"
  }
}
