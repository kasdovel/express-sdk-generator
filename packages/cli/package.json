{
  "name": "@kasdovel/express-sdkgen-cli",
  "version": "0.0.0",
  "description": "CLI that generates OpenAPI spec, docs, and a typed TS SDK from a @kasdovel/express-sdkgen-core registry",
  "author": "kasdovel <yoveln115@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kasdovel/express-sdk-generator.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/kasdovel/express-sdk-generator/issues"
  },
  "homepage": "https://github.com/kasdovel/express-sdk-generator/tree/master/packages/cli#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sdkgen": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@kasdovel/express-sdkgen-core": "workspace:*",
    "commander": "^12.1.0",
    "jiti": "^2.4.2",
    "redoc": "^2.2.0",
    "swagger-ui-dist": "^5.18.2",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "zod": "^3.24.1"
  }
}
