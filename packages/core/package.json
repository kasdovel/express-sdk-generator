{
  "name": "@sdkgen/core",
  "version": "0.0.0",
  "description": "Runtime helpers: createRoute, registry, request validation, serveDocs middleware",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "swagger-ui-express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/swagger-ui-express": "^4.1.7",
    "express": "^5.0.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  }
}
