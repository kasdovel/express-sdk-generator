{
  "name": "express-sdk-generator",
  "version": "0.0.0",
  "private": true,
  "description": "Generate OpenAPI spec, Swagger/Redoc docs, and a typed TS SDK from an Express + TypeScript app",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18"
  }
}
